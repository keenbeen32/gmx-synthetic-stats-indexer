# To create or update a token visit https://envio.dev/app/api-tokens
ENVIO_API_TOKEN="<YOUR-API-TOKEN>"

# Per-chain RPC URLs used by the Effect-API contract calls
# (Reader.getMarketTokenPrice and MarketToken.totalSupply). These calls are
# made at the event's historical block, so an ARCHIVE node is recommended.
# Public defaults are used if unset (see src/effects/client.ts).
#
# Contract-call tuning. By default calls are coalesced via JSON-RPC batching
# (no per-call rate limit). Only set ENVIO_RPC_RATE_LIMIT (calls/sec per effect) if your
# RPC still 429s with batching on — it serializes calls and slows sync.
# ENVIO_RPC_RATE_LIMIT="5"
# Max eth_calls per batched HTTP request (lower if the RPC rejects large batches).
ENVIO_RPC_BATCH_SIZE="50"
ENVIO_RPC_URL_42161="https://arb1.arbitrum.io/rpc"               # arbitrum-one
ENVIO_RPC_URL_43114="https://api.avax.network/ext/bc/C/rpc"      # avalanche
ENVIO_RPC_URL_43113="https://api.avax-test.network/ext/bc/C/rpc" # avalanche-fuji
ENVIO_RPC_URL_421613="https://goerli-rollup.arbitrum.io/rpc"     # arbitrum-goerli (deprecated)
ENVIO_RPC_URL_3637="https://rpc.botanixlabs.com"                 # botanix-mainnet
ENVIO_RPC_URL_4326="https://mainnet.megaeth.com/rpc"             # megaeth-mainnet
